#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

extra_command "update" "执行实时更新及测速"
extra_command "clear_cache" "清理无效及缓存文件"

update() {
    echo "[*] IPTV Ultra Pro: Starting stream updates..."
    # 运行高性能 Python 测速引擎
    /usr/bin/python3 /usr/bin/iptv-probe.py
    echo "[*] IPTV Ultra Pro: Update finished."
}

clear_cache() {
    rm -rf /www/iptv/*.m3u
    rm -rf /www/iptv/epg.xml
    uci set iptv-ultra.runtime.total_channels='0'
    uci set iptv-ultra.runtime.success_rate='0%'
    uci commit iptv-ultra
    echo "[*] IPTV Ultra Pro: Cache cleared."
}

# Procd 系统守护进程（可选，用于保持 HTTP 静态路径链接可用性）
start_service() {
    config_load 'iptv-ultra'
    config_get_bool enabled 'global' 'enabled' 0
    [ "$enabled" -eq 1 ] || return 0

    procd_open_instance
    procd_set_param command /bin/true
    procd_close_instance
    
    # 建立软链接，确保 HTTP 可达性 (如果 uhttpd 默认根目录是 /www)
    [ -d "/www/iptv" ] || mkdir -p /www/iptv
}